POSTGRES_DB_URL=your-postgres-url
DATABASE_URL=sqlite+aiosqlite:///data/claims.db
SYNC_DATABASE_URL=sqlite:///data/claims.db
DB_NAME=defaultdb
DB_HOST=localhost
DB_PORT=5432
DB_USER=avnadmin
DB_CONNECTION_STRING=your-db-connection-string
DB_PASSWORD=your-db-password
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_ALLOW_CREDENTIALS=false
ENABLE_EARTH_ENGINE=false
EARTH_ENGINE_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
ALLOW_DEMO_SATELLITE_FALLBACK=true
ALLOW_HEURISTIC_AI_FALLBACK=true
REQUIRE_TRAINED_AI_MODEL=false
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_API_KEY=your-google-api-key
AI_MODEL_PATH=models/crop_damage_cnn.keras
AI_MODEL_VERSION=v1
